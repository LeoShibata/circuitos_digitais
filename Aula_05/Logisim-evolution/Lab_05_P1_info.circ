	ff_d3:                  dff_vhdl port map(d =&gt; qn(3), prs =&gt; clr_aux,   clr =&gt; '0',    clk =&gt; qstate(2), q =&gt; qstate(3), qn =&gt; qn(3));
	ff_reset:               dff_vhdl port map(d =&gt; '0',   prs =&gt; ff_rst_in, clr =&gt; ff_rst, clk =&gt; '0',       q =&gt; ff_rst_out);
	ff_reset_alargador:     dff_vhdl port map(d =&gt; '0',   prs =&gt; prs_rst,   clr =&gt; clkn,   clk =&gt; '0',       q =&gt; ff_rst);
	ff_reset_clr_alargador: dff_vhdl port map(d =&gt; '0',   prs =&gt; zn,        clr =&gt; clkn,   clk =&gt; '0',       q =&gt; clr_alargador);
	clr_aux &lt;= '1' when clr_alargador = '1' else '0';
	q(0) &lt;= qstate(0);
	q(1) &lt;= qstate(1);
	q(2) &lt;= qstate(2);
	q(3) &lt;= qstate(3);
end cnt_down_mod10_alargador_arch;</vhdl>
