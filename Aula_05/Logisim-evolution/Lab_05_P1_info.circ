	component dff_vhdl is				
		port
		(
			d, clk, prs, clr	: in  std_logic;	
			q, qn				: out std_logic 	
		);
	end component;
	component divider is
	port(
		clk_in					: in  std_logic;	
		clk_out_1, clk_out_2	: out std_logic	
	);
	end component;
