    <comp lib="8" loc="(265,260)" name="Text">
      <a name="text" val="para que o o Logisim o renomeie para &quot;dff_vhdl&quot;"/>
    </comp>
    <comp lib="8" loc="(265,345)" name="Text">
      <a name="text" val="o Logisim utilizará um rótulo padrão tipo &quot;component_0&quot;,"/>
