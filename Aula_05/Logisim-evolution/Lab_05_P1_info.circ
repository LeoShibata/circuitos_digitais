architecture cnt_down_mod10_alargador_arch of P8_cnt_down_mod10_alargador_vhdl is
	signal zn: std_logic;
	signal qn: std_logic_vector(3 downto 0);	
	signal qstate: std_logic_vector(3 downto 0);
	signal rst, ff_rst_in, ff_rst_out, clkn, prs_rst, ff_rst, clr_alargador, clr_aux: std_logic;
	component dff_vhdl is					
		port
		(
			d, clk, prs, clr	: in  std_logic;
			q, qn			: out std_logic
		);
	end component;
begin
	zn &lt;= not z;
	clkn &lt;= not clk;
	rst &lt;= ff_rst_out and (qstate(0) and (qstate(1) and (qstate(2) and qstate(3))));
	ff_rst_in &lt;= not (qstate(0) or (qstate(1) or (qstate(2) or qstate(3))));
	prs_rst &lt;= rst or zn;
	ff_d0:                  dff_vhdl port map(d =&gt; qn(0), prs =&gt; clr_aux,   clr =&gt; '0',    clk =&gt; clk,       q =&gt; qstate(0), qn =&gt; qn(0));
	ff_d1:                  dff_vhdl port map(d =&gt; qn(1), prs =&gt; '0',       clr =&gt; ff_rst, clk =&gt; qstate(0), q =&gt; qstate(1), qn =&gt; qn(1));
