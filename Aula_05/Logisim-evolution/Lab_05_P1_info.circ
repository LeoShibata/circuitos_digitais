	signal zn: std_logic;
	signal qn: std_logic_vector(3 downto 0);
	signal qstate: std_logic_vector(3 downto 0);
	signal rst, ff_rst_in, ff_rst_out: std_logic;	
	component dff_vhdl is					
		port
		(
			d, clk, prs, clr	: in  std_logic;	
			q, qn			: out std_logic 	
		);
	end component;	
begin
	zn &lt;= not z;
	ff_rst_in &lt;= not (qstate(0) or (qstate(1) or (qstate(2) or qstate(3))));
	rst &lt;= ((not z) or (ff_rst_out and (qstate(0) and (qstate(1) and (qstate(2) and qstate(3))))));
	ff_d0: dff_vhdl  port map(d =&gt; qn(0), prs =&gt; rst,       clr =&gt; '0',  clk =&gt; clk,	  q =&gt; qstate(0), qn =&gt; qn(0));
	ff_d1: dff_vhdl  port map(d =&gt; qn(1), prs =&gt; '0',       clr =&gt; rst,  clk =&gt; qstate(0), q =&gt; qstate(1), qn =&gt; qn(1));
	ff_d2: dff_vhdl  port map(d =&gt; qn(2), prs =&gt; '0',       clr =&gt; rst,  clk =&gt; qstate(1), q =&gt; qstate(2), qn =&gt; qn(2));
	ff_d3: dff_vhdl  port map(d =&gt; qn(3), prs =&gt; rst,       clr =&gt; '0',  clk =&gt; qstate(2), q =&gt; qstate(3), qn =&gt; qn(3));
	ff_rst: dff_vhdl port map(d =&gt; '0',   prs =&gt; ff_rst_in, clr =&gt; rst,  clk =&gt; '0',       q =&gt; ff_rst_out);
	q(0) &lt;= qstate(0);
	q(1) &lt;= qstate(1);
	q(2) &lt;= qstate(2);
	q(3) &lt;= qstate(3);
end cnt_down_mod10_arch;</vhdl>
